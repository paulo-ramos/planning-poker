@inherits LayoutComponentBase

<div class="min-h-screen bg-gradient-to-br from-purple-600 via-blue-500 to-indigo-600">
    <header class="bg-white/10 backdrop-blur-md border-b border-white/20">
        <div class="container mx-auto px-4 py-4">
            <div class="flex items-center justify-between">
                <a href="/" class="flex items-center gap-3 text-white hover:opacity-80 transition-opacity">
                    <div class="text-4xl">🎴</div>
                    <h1 class="text-2xl font-bold">Planning Poker</h1>
                </a>
                <div class="text-white/80 text-sm">
                    Planeje seus sprints com sua equipe
                </div>
            </div>
        </div>
    </header>

    <main class="container mx-auto px-4 py-8">
        @Body
    </main>

    <footer class="fixed bottom-0 left-0 right-0 bg-black/20 backdrop-blur-md text-white/60 py-4 text-center text-sm">
        <p>Planning Poker © 2026 - Desenvolvido com ❤️ e Blazor by Paulo Ramos</p>
    </footer>
</div>
