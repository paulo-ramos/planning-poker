@page "/room/{roomId}"
@inject PlanningPokerService PokerService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject UserCircuitHandler CircuitHandler
@implements IDisposable

<PageTitle>Planning Poker - @room?.TeamName</PageTitle>

@if (room == null)
{
    <div class="max-w-2xl mx-auto">
        <div class="bg-white/95 backdrop-blur-sm rounded-3xl shadow-2xl p-8 text-center">
            <div class="text-6xl mb-4">😕</div>
            <h1 class="text-3xl font-bold text-gray-800 mb-4">Sala não encontrada</h1>
            <p class="text-gray-600 mb-6">A sala que você está tentando acessar não existe ou foi encerrada.</p>
            <a href="/" class="inline-block bg-purple-600 hover:bg-purple-700 text-white font-bold py-3 px-6 rounded-xl transition-colors">
                🏠 Voltar para Home
            </a>
        </div>
    </div>
}
else if (currentUser == null)
{
    <div class="max-w-md mx-auto">
        <div class="bg-white/95 backdrop-blur-sm rounded-3xl shadow-2xl p-8">
            <div class="text-center mb-6">
                <div class="text-5xl mb-4">👋</div>
                <h1 class="text-3xl font-bold text-gray-800 mb-2">Entrar na Sala</h1>
                <p class="text-gray-600">@room.TeamName - @room.SprintName</p>
            </div>

            <EditForm Model="@joinModel" OnValidSubmit="JoinRoom" class="space-y-4">
                <DataAnnotationsValidator />

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Seu Nome
                    </label>
                    <InputText @bind-Value="joinModel.Name"
                               class="w-full px-4 py-3 rounded-xl border-2 border-gray-200 focus:border-purple-500 focus:ring-4 focus:ring-purple-500/20 outline-none transition-all"
                               placeholder="Digite seu nome" />
                    <ValidationMessage For="@(() => joinModel.Name)" class="text-red-500 text-sm mt-1" />
                </div>

                <div>
                    <label class="block text-sm font-semibold text-gray-700 mb-2">
                        Seu Papel
                    </label>
                    <InputRadioGroup @bind-Value="joinModel.Role">
                        <div class="space-y-2">
                            <label class="flex items-center gap-2 p-2 rounded-lg border-2 border-gray-200 hover:border-purple-300 cursor-pointer transition-all">
                                <InputRadio Value="@UserRole.Dev" class="w-4 h-4 text-purple-600" />
                                <div class="text-sm">
                                    <span class="font-semibold text-gray-800">👨‍💻 Desenvolvedor (Dev)</span>
                                </div>
                            </label>
                            <label class="flex items-center gap-2 p-2 rounded-lg border-2 border-gray-200 hover:border-purple-300 cursor-pointer transition-all">
                                <InputRadio Value="@UserRole.QA" class="w-4 h-4 text-purple-600" />
                                <div class="text-sm">
                                    <span class="font-semibold text-gray-800">🧪 QA/Tester (QA)</span>
                                </div>
                            </label>
                            <label class="flex items-center gap-2 p-2 rounded-lg border-2 border-gray-200 hover:border-purple-300 cursor-pointer transition-all">
                                <InputRadio Value="@UserRole.Observer" class="w-4 h-4 text-purple-600" />
                                <div class="text-sm">
                                    <span class="font-semibold text-gray-800">👀 Observador</span>
                                </div>
                            </label>
                        </div>
                    </InputRadioGroup>
                </div>

                <button type="submit"
                        class="w-full bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-700 hover:to-indigo-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg hover:shadow-xl transform hover:scale-[1.02] transition-all">
                    🚀 Entrar na Sala
                </button>
            </EditForm>
        </div>
    </div>
}
else if (currentUser != null)
{
    <div class="max-w-7xl mx-auto space-y-6">
        <!-- Notificações -->
        @if (room.Notifications.Any())
        {
            <div class="fixed top-20 right-4 z-50 space-y-2 max-w-md">
                @foreach (var notification in room.Notifications.TakeLast(3))
                {
                    var bgColor = notification.Type == NotificationType.Warning 
                        ? "bg-red-500 border-red-700" 
                        : "bg-green-500 border-green-700";
                    
                    <div class="@bgColor text-white px-4 py-3 rounded-xl shadow-lg border-2 animate-slide-in-right">
                        <div class="flex items-center gap-2">
                            <span class="text-lg">@(notification.Type == NotificationType.Warning ? "⚠️" : "ℹ️")</span>
                            <span class="font-semibold">@notification.Message</span>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Header da Sala -->
        <div class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
                <div>
                    <h1 class="text-3xl font-bold text-gray-800">@room.TeamName</h1>
                    <p class="text-gray-600">@room.SprintName - Rodada #@room.RoundNumber</p>
                </div>
                <div class="flex items-center gap-2">
                    <span class="px-4 py-2 bg-purple-100 text-purple-700 rounded-xl font-semibold">
                        👥 @room.Users.Count @(room.Users.Count == 1 ? "participante" : "participantes")
                    </span>
                    <button @onclick="CopyRoomLink"
                            class="px-4 py-2 bg-gray-100 hover:bg-gray-200 text-gray-700 rounded-xl font-semibold transition-colors">
                        🔗 Copiar Link
                    </button>
                </div>
            </div>
        </div>

        <div class="grid md:grid-cols-3 gap-6">
            <!-- Painel de Votação -->
            <div class="md:col-span-2 space-y-6">
                <!-- Cards de Votação -->
                <div class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
                    <h2 class="text-xl font-bold text-gray-800 mb-4">🎴 Escolha sua estimativa</h2>

                    @if (!room.VotesRevealed)
                    {
                        <div class="grid grid-cols-4 sm:grid-cols-5 md:grid-cols-6 lg:grid-cols-7 gap-3">
                            @foreach (var value in room.VotingSequence)
                            {
                                var isSelected = room.Votes.ContainsKey(currentUser.Id) && room.Votes[currentUser.Id].Value == value;
                                var cardClass = isSelected
                                    ? "bg-gradient-to-br from-purple-600 to-indigo-600 text-white scale-110 shadow-xl"
                                    : "bg-white hover:bg-gradient-to-br hover:from-purple-50 hover:to-indigo-50 text-gray-800 hover:scale-105 hover:shadow-lg";

                                <button @onclick="() => CastVote(value)"
                                        class="@cardClass aspect-[2/3] rounded-xl border-2 border-gray-200 font-bold text-2xl transition-all duration-200 flex items-center justify-center">
                                    @value
                                </button>
                            }
                        </div>

                        @if (room.Votes.ContainsKey(currentUser.Id))
                        {
                            <div class="mt-4 p-4 bg-green-100 border-2 border-green-300 rounded-xl text-green-700 text-center">
                                ✅ Você votou! Aguardando os outros participantes...
                            </div>
                        }
                    }
                    else
                    {
                        <!-- Votos Revelados -->
                        <div class="space-y-4">
                            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4">
                                @foreach (var user in GetSortedUsersForReveal())
                                {
                                    var hasVoted = room.Votes.ContainsKey(user.Id);
                                    var voteValue = hasVoted ? room.Votes[user.Id].Value : "";
                                    var isAbsentee = voteValue == "☕" || voteValue == "🚽";
                                    var cardStyle = isAbsentee
                                        ? "bg-gradient-to-br from-orange-50 to-yellow-50 border-orange-300"
                                        : user.Role == UserRole.QA
                                            ? "bg-gradient-to-br from-green-50 to-green-100 border-green-300"
                                            : user.Role == UserRole.Dev
                                                ? "bg-gradient-to-br from-blue-50 to-blue-100 border-blue-300"
                                                : "bg-gradient-to-br from-red-50 to-red-100 border-red-300";

                                    <div class="@cardStyle rounded-xl p-4 border-2">
                                        <div class="flex items-center gap-2 mb-2">
                                            <span class="text-lg">@GetRoleIcon(user.Role)</span>
                                            <img src="@user.AvatarUrl" alt="@user.Name" class="w-8 h-8 rounded-full" />
                                            <span class="font-semibold text-sm text-gray-800 truncate">@user.Name</span>
                                        </div>
                                        <div class="text-center">
                                            @if (hasVoted)
                                            {
                                                var voteColor = isAbsentee ? "text-orange-600" :
                                                                user.Role == UserRole.QA ? "text-green-700" :
                                                                user.Role == UserRole.Dev ? "text-blue-700" :
                                                                "text-red-700";
                                                <div class="text-3xl font-bold @voteColor">
                                                    @voteValue
                                                </div>
                                                @if (isAbsentee)
                                                {
                                                    <div class="text-xs text-orange-600 mt-1">Ausente</div>
                                                }
                                                @if (user.Role == UserRole.Observer)
                                                {
                                                    <div class="text-xs text-red-600 mt-1">Não conta</div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="text-gray-400 text-sm">Não votou</div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- Médias por Grupo e Estimativa Final -->
                            @{
                                var devAvg = room.GetVotesAverageByRole(UserRole.Dev);
                                var qaAvg = room.GetVotesAverageByRole(UserRole.QA);
                                var combined = room.GetCombinedAverage();
                                var finalEstimate = room.GetFinalEstimate();
                                var devVotesDistribution = GetDevVotesDistribution();
                            }

                            @if (devAvg.HasValue || qaAvg.HasValue || combined.HasValue)
                            {
                                <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
                                    @if (qaAvg.HasValue)
                                    {
                                        <div class="bg-gradient-to-br from-green-100 to-green-200 rounded-xl p-3 border-2 border-green-300">
                                            <div class="text-xs font-semibold text-green-900 mb-1">🧪 QA</div>
                                            <div class="text-3xl font-bold text-green-900">@qaAvg.Value.ToString("F1")</div>
                                        </div>
                                    }
                                    @if (devAvg.HasValue)
                                    {
                                        <div class="bg-gradient-to-br from-blue-100 to-blue-200 rounded-xl p-3 border-2 border-blue-300">
                                            <div class="text-xs font-semibold text-blue-900 mb-1">👨‍💻 DEV</div>
                                            <div class="text-3xl font-bold text-blue-900">@devAvg.Value.ToString("F1")</div>
                                        </div>
                                    }
                                    @if (combined.HasValue && finalEstimate != null)
                                    {
                                        <div class="bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-xl p-3 border-2 border-purple-700">
                                            <div class="text-xs font-semibold mb-1">🎯 FINAL</div>
                                            <div class="text-3xl font-bold">@finalEstimate</div>
                                            <div class="text-xs opacity-80 mt-0.5">@(devAvg?.ToString("F1") ?? "0") + @(qaAvg?.ToString("F1") ?? "0")</div>
                                        </div>
                                    }
                                    @if (devVotesDistribution.Any())
                                    {
                                        <div class="bg-gradient-to-br from-gray-100 to-gray-200 rounded-xl p-3 border-2 border-gray-300">
                                            <div class="text-xs font-semibold text-gray-900 mb-2">📊 DIST. DEV</div>
                                            <div class="space-y-1">
                                                @foreach (var (vote, count) in devVotesDistribution.OrderBy(kv => double.TryParse(kv.Key, out var n) ? n : 999))
                                                {
                                                    <div class="flex items-center gap-1 text-xs">
                                                        <span class="font-bold text-gray-800 w-6">@vote:</span>
                                                        <div class="flex-1 bg-blue-400 rounded h-3" style="width: @(count * 100.0 / devVotesDistribution.Values.Max())%"></div>
                                                        <span class="text-gray-700 font-semibold w-4">@count</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else if (room.GetVotesAverage().HasValue)
                            {
                                <!-- Fallback para quando não há divisão por grupos -->
                                <div class="bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-2xl p-6 text-center">
                                    <div class="text-sm font-semibold mb-2">📊 MÉDIA</div>
                                    <div class="text-5xl font-bold">@room.GetVotesAverage()?.ToString("F1")</div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Ações do Moderador -->
                @if (currentUser.IsModerator)
                {
                    <div class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20">
                        <h2 class="text-xl font-bold text-gray-800 mb-4">🎮 Controles do Moderador</h2>
                        <div class="flex flex-wrap gap-3">
                            @if (!room.VotesRevealed)
                            {
                                <button @onclick="RevealVotes"
                                        class="flex-1 bg-gradient-to-r from-green-600 to-emerald-600 hover:from-green-700 hover:to-emerald-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-all">
                                    👁️ Revelar Votos @(room.AllUsersVoted() ? "✅" : $"({room.Votes.Count}/{room.Users.Count(u => u.Value.IsConnected)})")
                                </button>
                            }
                            <button @onclick="ResetVoting"
                                    class="flex-1 bg-gradient-to-r from-blue-600 to-cyan-600 hover:from-blue-700 hover:to-cyan-700 text-white font-bold py-3 px-6 rounded-xl shadow-lg transition-all">
                                🔄 Nova Rodada
                            </button>
                        </div>
                    </div>
                }

                <!-- Instruções de Referência -->
                @if (!string.IsNullOrWhiteSpace(room.Instructions))
                {
                    <div class="bg-gradient-to-br from-yellow-100 to-yellow-200 rounded-2xl shadow-xl p-6 border-2 border-yellow-400">
                        <h2 class="text-lg font-bold text-yellow-900 mb-3 flex items-center gap-2">
                            📋 Instruções de Referência
                        </h2>
                        <pre class="text-sm text-yellow-900 font-mono whitespace-pre-wrap leading-relaxed">@room.Instructions</pre>
                    </div>
                }
            </div>

            <!-- Painel de Participantes -->
            <div class="md:col-span-1">
                <div class="bg-white/95 backdrop-blur-sm rounded-2xl shadow-xl p-6 border border-white/20 sticky top-4">
                    <h2 class="text-xl font-bold text-gray-800 mb-4">👥 Participantes</h2>
                    <div class="space-y-3">
                        @foreach (var user in GetSortedParticipants())
                        {
                            var hasVoted = room.Votes.ContainsKey(user.Id);
                            var statusColor = room.VotesRevealed ? "bg-gray-200" : (hasVoted ? "bg-green-500" : "bg-yellow-400");
                            var isCurrentUser = user.Id == currentUser?.Id;
                            var canShoot = !isCurrentUser && !hasVoted && !room.VotesRevealed;
                            var cursorClass = canShoot ? "cursor-pointer hover:scale-105 hover:shadow-lg" : "opacity-50 cursor-not-allowed";
                            var roleBackgroundClass = GetRoleBackgroundClass(user.Role);

                            <div data-user-id="@user.Id"
                                 @onclick="() => FireCannonAt(user.Id, hasVoted)"
                                 class="@cursorClass flex items-center gap-3 p-3 rounded-xl @roleBackgroundClass transition-all">
                                <img src="@user.AvatarUrl" alt="@user.Name" class="w-10 h-10 rounded-full" />
                                <div class="flex-1 min-w-0">
                                    <div class="font-semibold text-gray-800 truncate">@user.Name</div>
                                    <div class="flex items-center gap-2 text-xs">
                                        @if (user.IsModerator)
                                        {
                                            <span class="text-purple-600 font-semibold">👑 Moderador</span>
                                        }
                                        <span class="@GetRoleBadgeClass(user.Role)">
                                            @GetRoleIcon(user.Role) @GetRoleName(user.Role)
                                        </span>
                                    </div>
                                </div>
                                <div class="@statusColor w-3 h-3 rounded-full" title="@(hasVoted ? "Votou" : "Aguardando")"></div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Canhão Fixo no Canto Inferior Esquerdo -->
        <div class="fixed bottom-24 left-8 z-50">
            <div id="cannon-icon" class="text-6xl transform -rotate-45 drop-shadow-2xl" title="Clique em um participante para atirar!">
                💣
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public string RoomId { get; set; } = string.Empty;

    [SupplyParameterFromQuery]
    public string? UserId { get; set; }

    private Models.Room? room;
    private Models.User? currentUser;
    private JoinRoomModel joinModel = new();
    private string? lastCannonShotId;
    private readonly string connectionId = Guid.NewGuid().ToString();

    protected override void OnInitialized()
    {
        // Verifica se a sala existe imediatamente
        room = PokerService.GetRoom(RoomId);

        // Se vier userId na URL, tenta recuperar o usuário
        if (room != null && !string.IsNullOrEmpty(UserId))
        {
            if (room.Users.TryGetValue(UserId, out currentUser))
            {
                // Registra a conexão do usuário existente
                PokerService.RegisterUserConnection(connectionId, RoomId, currentUser.Id);
            }
        }

        PokerService.RoomUpdated += OnRoomUpdated;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && room != null && currentUser == null)
        {
            // Tenta recuperar userId do sessionStorage
            var storedUserId = await JSRuntime.InvokeAsync<string?>("getUserId", RoomId);

            if (!string.IsNullOrEmpty(storedUserId) && room.Users.TryGetValue(storedUserId, out currentUser))
            {
                // Registra a conexão do usuário recuperado
                PokerService.RegisterUserConnection(connectionId, RoomId, currentUser.Id);
                await InvokeAsync(StateHasChanged);
            }

            // Se veio userId na URL, salva no sessionStorage e limpa a URL
            if (!string.IsNullOrEmpty(UserId))
            {
                await JSRuntime.InvokeVoidAsync("saveUserId", RoomId, UserId);
                Navigation.NavigateTo($"/room/{RoomId}", forceLoad: false);
            }
        }
    }

    private async void OnRoomUpdated(string roomId)
    {
        if (roomId == RoomId)
        {
            var updatedRoom = PokerService.GetRoom(RoomId);

            // Detecta novo disparo de canhão
            if (updatedRoom?.LastCannonShot != null &&
                updatedRoom.LastCannonShot.Id != lastCannonShotId)
            {
                lastCannonShotId = updatedRoom.LastCannonShot.Id;

                // Anima o disparo
                await JSRuntime.InvokeVoidAsync("animateCannonShot",
                    updatedRoom.LastCannonShot.FromUserId,
                    updatedRoom.LastCannonShot.ToUserId,
                    updatedRoom.LastCannonShot.Projectile);
            }

            room = updatedRoom;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task JoinRoom()
    {
        if (room == null) return;

        currentUser = PokerService.JoinRoom(RoomId, joinModel.Name, joinModel.Role);

        if (currentUser != null)
        {
            // Registra a conexão do novo usuário
            PokerService.RegisterUserConnection(connectionId, RoomId, currentUser.Id);
            
            // Salva userId no sessionStorage
            await JSRuntime.InvokeVoidAsync("saveUserId", RoomId, currentUser.Id);

            // Atualiza a UI para mostrar a sala
            StateHasChanged();
        }
    }

    private void CastVote(string value)
    {
        if (currentUser == null || room == null || room.VotesRevealed) return;

        PokerService.Vote(RoomId, currentUser.Id, value);
    }

    private void RevealVotes()
    {
        PokerService.RevealVotes(RoomId);
    }

    private void ResetVoting()
    {
        PokerService.ResetVoting(RoomId);
    }

    private void FireCannonAt(string targetUserId, bool targetHasVoted)
    {
        // Não pode atirar em si mesmo, em quem já votou, ou depois dos votos revelados
        if (currentUser == null || room == null ||
            targetUserId == currentUser.Id ||
            targetHasVoted ||
            room.VotesRevealed)
            return;

        PokerService.FireCannon(RoomId, currentUser.Id, targetUserId);
    }

    private IEnumerable<Models.User> GetSortedUsersForReveal()
    {
        if (room == null) return Enumerable.Empty<Models.User>();

        return room.Users.Values
            .OrderBy(user => 
            {
                // Ordena por Role: QA primeiro (0), depois Dev (1), depois Observer (2)
                return user.Role switch
                {
                    UserRole.QA => 0,
                    UserRole.Dev => 1,
                    UserRole.Observer => 2,
                    _ => 3
                };
            })
            .ThenBy(user =>
            {
                // Dentro de cada grupo, ordena por voto
                if (!room.Votes.ContainsKey(user.Id))
                    return int.MaxValue;

                var voteValue = room.Votes[user.Id].Value;

                // Ausentes (☕ ou 🚽) vão para o final
                if (voteValue == "☕" || voteValue == "🚽")
                    return 9999;

                // Tenta converter o voto para número
                if (double.TryParse(voteValue, out var numericValue))
                    return numericValue;

                // Votos não numéricos (XS, S, M, etc) vão no meio
                return 999;
            })
            .ThenBy(user => user.Name); // Desempate alfabético
    }

    private Dictionary<string, int> GetDevVotesDistribution()
    {
        if (room == null) return new Dictionary<string, int>();

        var devUserIds = room.Users.Values
            .Where(u => u.Role == UserRole.Dev)
            .Select(u => u.Id)
            .ToHashSet();

        return room.Votes.Values
            .Where(v => devUserIds.Contains(v.UserId))
            .Where(v => !string.IsNullOrEmpty(v.Value) && v.Value != "☕" && v.Value != "🚽")
            .GroupBy(v => v.Value)
            .ToDictionary(g => g.Key, g => g.Count());
    }

    private string GetRoleIcon(UserRole role)
    {
        return role switch
        {
            UserRole.Dev => "👨‍💻",
            UserRole.QA => "🧪",
            UserRole.Observer => "👀",
            _ => "👤"
        };
    }

    private string GetRoleName(UserRole role)
    {
        return role switch
        {
            UserRole.Dev => "Dev",
            UserRole.QA => "QA",
            UserRole.Observer => "Observador",
            _ => ""
        };
    }

    private string GetRoleBadgeClass(UserRole role)
    {
        return role switch
        {
            UserRole.Dev => "text-blue-700 bg-blue-100 px-2 py-0.5 rounded font-semibold",
            UserRole.QA => "text-green-700 bg-green-100 px-2 py-0.5 rounded font-semibold",
            UserRole.Observer => "text-gray-700 bg-gray-100 px-2 py-0.5 rounded font-semibold",
            _ => "text-gray-600"
        };
    }

    private string GetRoleBackgroundClass(UserRole role)
    {
        return role switch
        {
            UserRole.Dev => "bg-gradient-to-r from-blue-50 to-blue-100 border border-blue-300",
            UserRole.QA => "bg-gradient-to-r from-green-50 to-green-100 border border-green-300",
            UserRole.Observer => "bg-gradient-to-r from-red-50 to-red-100 border border-red-300",
            _ => "bg-gradient-to-r from-purple-50 to-indigo-50 border border-purple-200"
        };
    }

    private IEnumerable<Models.User> GetSortedParticipants()
    {
        if (room == null) return Enumerable.Empty<Models.User>();

        return room.Users.Values
            .OrderBy(user =>
            {
                // Moderador sempre primeiro
                if (user.IsModerator) return 0;

                // Depois por papel: QA, Dev, Observer
                return user.Role switch
                {
                    UserRole.QA => 1,
                    UserRole.Dev => 2,
                    UserRole.Observer => 3,
                    _ => 4
                };
            })
            .ThenBy(user => user.Name); // Ordem alfabética dentro de cada grupo
    }

    private async Task CopyRoomLink()
    {
        // Copia apenas o link da sala, sem userId
        var baseUri = Navigation.BaseUri.TrimEnd('/');
        var roomLink = $"{baseUri}/room/{RoomId}";

        var success = await JSRuntime.InvokeAsync<bool>("copyToClipboard", roomLink);

        if (success)
        {
            await JSRuntime.InvokeVoidAsync("showToast", "✅ Link copiado! Compartilhe com seu time.", "success");
        }
        else
        {
            await JSRuntime.InvokeVoidAsync("showToast", "❌ Erro ao copiar link", "error");
        }
    }

    public void Dispose()
    {
        // Remove o event handler
        PokerService.RoomUpdated -= OnRoomUpdated;
        
        // Desregistra a conexão
        PokerService.UnregisterUserConnection(connectionId);
    }

    public class JoinRoomModel
    {
        [Required(ErrorMessage = "Por favor, informe seu nome")]
        public string Name { get; set; } = string.Empty;

        public UserRole Role { get; set; } = UserRole.Dev;
    }
}
